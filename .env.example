GROQ_API_KEY=gsk_YOUR_KEY_HERE

# Comma-separated list of allowed origins (no spaces)
# Production example: ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Auth
JWT_SECRET=
SERVICE_TOKEN=
SESSION_ENCRYPTION_KEY=

# Patient PII encryption (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
PATIENT_ENCRYPTION_KEY=your-fernet-key-here

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.com

# Frontend → backend proxy
BACKEND_URL=http://localhost:8001

# Frontend env (frontend/.env.local)
# Local: /backend-api  |  Vercel: set automatically via BACKEND_URL
NEXT_PUBLIC_API_URL=/backend-api
